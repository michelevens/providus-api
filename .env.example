APP_NAME=Credentik
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Railway provides DATABASE_URL; the app parses it automatically
DB_CONNECTION=pgsql
DATABASE_URL=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Sanctum / Auth
SANCTUM_STATEFUL_DOMAINS=

# CORS — comma-separated additional origins beyond github.io
CORS_ALLOWED_ORIGINS=https://app.credentik.com,https://michelevens.github.io

# Frontend URL (for password resets, email links, etc.)
FRONTEND_URL=https://app.credentik.com

# Mail (Resend)
MAIL_MAILER=resend
RESEND_API_KEY=
MAIL_FROM_ADDRESS=noreply@credentik.com
MAIL_FROM_NAME=Credentik

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# Seeder passwords (not stored in code)
SUPERADMIN_PASSWORD=
DEMO_USER_PASSWORD=

GRANTS_GOV_API_KEY=
SAM_GOV_API_KEY=
